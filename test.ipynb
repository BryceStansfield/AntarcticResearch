    "import pandas as pd\n",
    "\n",
    "facilities = pd.read_csv(\"Facilities_Nov2024.csv\", encoding=\"ISO-8859-1\")\n",
    "facilities[\"Peak Population\"] = facilities[\"Peak Population\"].str.replace(\",\", \"0\").astype(float)\n",
    "facilities.groupby(\"Operator (primary)\")[\"Peak Population\"].sum()\n"
